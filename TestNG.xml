<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Suite" parallel="tests" thread-count="2">

    <listeners>
        <listener class-name="listeners.TestNGListners"/>
    </listeners>

    <test name="ChromeTest">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="testMethods.FirstTest">   <!-- open tag! -->
                <methods>
                    <include name="validate_blank_field_validation_message"/>
            		<include name="validate_login_feature_with_wrong_userpassword"/>
            		<include name="validate_login_feature_with_valid_credentials"/>
            		<include name="validate_dashboardPage_item_List"/>
                </methods>
            </class>                               <!-- close here! -->
        </classes>
    </test>

    <!-- Firefox test disabled — uncomment to enable -->
